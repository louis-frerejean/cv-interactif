# API_KEY: Required for Gemini AI API calls.
# Create your key at https://aistudio.google.com/ → Get API key → Create API key
# In production (Netlify), set this as an environment variable.
API_KEY="MY_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
